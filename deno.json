{
  "fmt": {
    "indentWidth": 2,
    "lineWidth": 120,
    "singleQuote": true,
    "spaceSurroundingProperties": true,
    "trailingCommas": "onlyMultiLine",
    "useBraces": "preferNone"
  },
  "imports": {
    "@/": "./",
    "@std/dotenv": "jsr:@std/dotenv@^0.225.6",
    "color": "npm:color@^5.0.3",
    "web-ext": "npm:web-ext@^10.0.0"
  },
  "license": "GPL-3.0-or-later",
  "lint": {
    "rules": {
      "include": [
        "default-param-last",
        "eqeqeq",
        "no-eval",
        "no-non-null-asserted-optional-chain",
        "no-non-null-assertion",
        "no-useless-rename",
        "prefer-ascii",
        "single-var-declarator",
        "triple-slash-reference",
        "valid-typeof"
      ],
      "tags": [
        "recommended"
      ]
    }
  },
  "minimumDependencyAge": "P2D",
  "tasks": {
    "sign": {
      "command": "deno x web-ext sign",
      "dependencies": ["build"]
    },
    "build": {
      "command": "deno x web-ext build",
      "dependencies": [
        "pre"
      ]
    },
    "check": "deno check",
    "format": "deno fmt",
    "lint": {
      "dependencies": [
        "lint:ts",
        "lint:webext"
      ]
    },
    "lint:ts": "deno lint",
    "lint:webext": "deno x web-ext lint",
    "pre": {
      "dependencies": [
        "check",
        "lint",
        "format"
      ]
    },
    "run": "deno x web-ext run"
  }
}
